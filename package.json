{
  "name": "pharos-agent-settlement",
  "version": "0.1.0",
  "description": "Policy-controlled payments, escrow, paid API access, and verifiable settlement proofs for AI agents on Pharos.",
  "type": "module",
  "bin": {
    "pharos-settlement": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": ["dist", "skill", "contracts/src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:contracts": "cd contracts && forge test",
    "check": "npm run build && npm test && npm run test:contracts"
  },
  "dependencies": {
    "@x402/core": "^2.0.0",
    "@x402/evm": "^2.0.0",
    "@x402/fetch": "^2.0.0",
    "commander": "^14.0.2",
    "viem": "^2.38.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  },
  "engines": {
    "node": ">=20"
  }
}
