PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
# Optional comma-separated providers; the runtime retries and falls back in order.
PHAROS_RPC_URLS=
PHAROS_PRIVATE_KEY=
PHAROS_VAULT_ADDRESS=
PHAROS_ESCROW_ADDRESS=
PHAROS_REGISTRY_ADDRESS=
PHAROS_MODE=propose
PHAROS_X402_MAX_AMOUNT=1000000
PHAROS_JOURNAL_PATH=settlement-journal.jsonl
